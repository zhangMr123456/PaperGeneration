-- 閸掓稑缂撻惌銉ㄧ槕閻愮銆�
CREATE TABLE knowledge_point (
    -- 娑撳鏁崪灞界唨绾拷娣団剝浼�
    id INT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY COMMENT '閻儴鐦戦悙绗紻',
    outline_id INT UNSIGNED COMMENT '婢堆呯堪ID',
    document_id INT UNSIGNED COMMENT '閺傚洦銆侷D',
    code VARCHAR(100) NOT NULL COMMENT '閺嶇厧绱℃稉锟�"{{鐎涳妇顫杴}-{{鐠囩偓婀伴崥宥囆瀩}-{{濞堜絻鎯ゆ惔蹇撳娇}}-{{閻儴鐦戦悙鐟扮碍閸欑┃}"',
    name VARCHAR(200) NOT NULL COMMENT '娑擄拷閸欍儴鐦介崣顖氭嚒妫版娈戦惌銉ㄧ槕閻愮懓鎮曠粔甯礄婵″偊绱拌劤鑴抽惃鍕儓娑旓拷/鐟曚焦鐪�/鐎圭偟骞囩捄顖氱窞閿涳拷',
    level ENUM('unknown', 'primary', 'secondary', 'tertiary') NOT NULL DEFAULT 'unknown' COMMENT '閻儴鐦戦悙鐟扮湴缁撅拷',

    -- 閸ユ稓鏁ゆ禍褏澧� - 娴ｈ法鏁SON鐎涙ê鍋嶅畵灞筋殰缂佹挻鐎�
    teaching_for_lecture JSON NOT NULL COMMENT '閺佹瑥顒熼悽銊唹缁嬶拷',
    review_for_memorization JSON NOT NULL COMMENT '婢跺秳绡勯悽銊唶韫囧棙娼楅弬锟�',
    assessment_for_questions JSON NOT NULL COMMENT '閼板啳鐦庨悽銊ㄧ槸妫帮拷',
    scoring_for_grading JSON NOT NULL COMMENT '鐠囧嫬鍨庨悽銊︾垼閸戯拷',

    -- 閺佹壆绮嶇�涙顔屾担璺ㄦ暏JSON鐎涙ê鍋�
    evidence_sentences JSON NOT NULL COMMENT '閺�顖涙嫼鐠囥儳鐓＄拠鍡欏仯閻ㄥ嫭鏆�閺夋劕甯崣銉礄1-3閸欍儻绱�',

    -- 閸忓啯鏆熼幑锟�
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '閸掓稑缂撻弮鍫曟？',
    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '閺囧瓨鏌婇弮鍫曟？',

    -- 缁便垹绱�
    INDEX idx_outline_id (document_id, outline_id, level),
    INDEX idx_code (code),

    -- 閸烆垯绔寸痪锔芥将
    UNIQUE KEY uk_code (code)

